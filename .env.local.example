# Copy this file to .env.local and fill in real values.
# .env.local is gitignored so secrets stay local.

# From Supabase → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJI...your-anon-key

# Used only by Supabase Edge Functions (server-side). Do NOT prefix VITE_.
# Set as Supabase secret instead:  supabase secrets set GEMINI_API_KEY=...
GEMINI_API_KEY=your-gemini-api-key
